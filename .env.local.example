# Supabase — from Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=ey...
SUPABASE_SERVICE_ROLE_KEY=ey...

# Anthropic — for prompt parsing
ANTHROPIC_API_KEY=sk-ant-...

# Google OAuth — the SAME client_id and secret you pasted into Supabase's
# Google auth provider settings. We need them server-side so we can refresh
# the user's access token when calling FreeBusy.
GOOGLE_CLIENT_ID=...apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...

# App
# Used in OAuth redirects and share-link URLs. No trailing slash.
NEXT_PUBLIC_APP_URL=http://localhost:3000
